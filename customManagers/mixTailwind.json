{
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm",
      "depNameTemplate": "tailwindcss",
      "managerFilePatterns": ["^config/config\\.exs$"],
      "matchStrings": [
        "config\\s+:tailwind,\\s+version:\\s*\"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
